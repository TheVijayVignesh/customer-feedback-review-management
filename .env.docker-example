# ==============================================================================
# DOCKER COMPOSE ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env and fill in your values
# Used by docker-compose.yml on EC2

# MySQL Database Configuration
MYSQL_DATABASE=feedback_db
MYSQL_USER=feedback_user
MYSQL_PASSWORD=your-super-strong-password-here
MYSQL_ROOT_PASSWORD=your-strong-root-password-here

# Backend API Configuration
JWT_SECRET=your-32-character-jwt-secret-key-here
CORS_ORIGIN=http://your-ec2-domain.com

# Frontend Configuration
VITE_API_BASE_URL=http://your-ec2-domain.com:8080/api

# Docker Network (leave as default)
NETWORK_NAME=feedback-net

# Optional: MySQL Timezone
# TZ=UTC
